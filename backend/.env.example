# ===============================================
# Viet Horizon Travel - Environment Configuration
# ===============================================
# Copy this file to .env and update values

# --- Application ---
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_URL=http://localhost:8080

# --- Database ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=viet_horizon_travel
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# --- JWT Authentication ---
JWT_SECRET=change-this-secret-in-production
JWT_ISSUER=viet-horizon.travel
JWT_AUDIENCE=viet-horizon.clients
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5500,http://localhost:8080

# --- Frontend URL ---
FRONTEND_URL=http://localhost/DACS2

# --- Mail ---
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME=Viet Horizon Travel
MAIL_TRANSPORT=mail
MAIL_SMTP_HOST=localhost
MAIL_SMTP_PORT=25
MAIL_SMTP_USER=
MAIL_SMTP_PASS=
MAIL_SMTP_SECURE=
MAIL_LOG_PREVIEW=true

# --- MoMo Payment ---
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api
MOMO_REDIRECT_URL=http://localhost/DACS2/pages/booking-payment.html
MOMO_IPN_URL=http://localhost:8080/api/payment/momo/ipn

# --- VNPay Payment ---
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost/DACS2/pages/booking-payment.html

# --- AI Chat (Google Gemini) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
